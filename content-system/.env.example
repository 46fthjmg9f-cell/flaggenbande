# development | production
FLAGGENBANDE_MODE=development

# Optional overrides. No credentials belong in this file.
FLAGGENBANDE_LOG_LEVEL=debug
FLAGGENBANDE_OUTPUT_DIR=./output

# Durable data, assets, releases and output. Keep dependencies and caches local.
FLAGGENBANDE_CLOUD_ROOT=
FLAGGENBANDE_LOCAL_CACHE_DIR=./.cache
