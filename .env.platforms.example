# This file is server-side only. Copy it to .env.platforms locally.
# In GitHub, add the same names under Settings > Secrets and variables > Actions.

# Preferred cloud bridge. It contains public, pre-aggregated metrics only; raw
# OAuth secrets remain in their original server-side systems.
SOCIAL_ANALYTICS_FEED_URL=https://factverse-meta-scheduler.example.workers.dev/analytics/feed

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
YOUTUBE_REDIRECT_URI=http://127.0.0.1:53682/oauth2callback
YOUTUBE_CATEGORY_ID=27
# Existing FactVerse setups may use this equivalent name instead:
# YOUTUBE_ANALYTICS_REFRESH_TOKEN=

META_GRAPH_API_VERSION=v24.0
# Instagram Login token (graph.instagram.com)
META_ACCESS_TOKEN=
META_INSTAGRAM_ACCESS_TOKEN=
META_INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCOUNT_ID=
# Facebook Page token (graph.facebook.com); do not reuse the Instagram token.
META_FACEBOOK_PAGE_ACCESS_TOKEN=
META_FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# A direct access token works for one day. The refresh credential set is the
# durable server-side option; TikTok may rotate its refresh token.
TIKTOK_ACCESS_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# Strictly non-publishing upload-test lane. The state directory is private and
# keeps cross-run idempotency; it must never point into dashboard/public.
UPLOAD_STAGING_STATE_DIR=.state/upload-staging
UPLOAD_STAGING_API_URL=https://factverse-meta-scheduler.example.workers.dev
UPLOAD_STAGING_API_TOKEN=
# Optional but recommended: exact hostname pin for the bearer-token destination.
UPLOAD_STAGING_ALLOWED_HOST=factverse-meta-scheduler.example.workers.dev
# Public, sanitized status feed consumed by the dashboard collector.
UPLOAD_STAGING_FEED_URL=https://factverse-meta-scheduler.example.workers.dev/staging/feed
