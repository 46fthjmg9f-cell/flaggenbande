# Online operator API. Secrets must be configured with `wrangler secret put`.
OPERATOR_API_TOKEN=
OPERATOR_RUNNER_TOKEN=

# Local outbound runner. It never opens an inbound port.
OPERATOR_API_URL=https://flaggenbande-operator-api.example.workers.dev
OPERATOR_RUNNER_ID=flaggenbande-mac
VIDEO_CONTROL_API_URL=http://127.0.0.1:4317
OPERATOR_POLL_INTERVAL_MS=5000
OPERATOR_REQUEST_TIMEOUT_MS=15000
OPERATOR_LOCAL_POLL_INTERVAL_MS=1500
OPERATOR_LEASE_SECONDS=60
