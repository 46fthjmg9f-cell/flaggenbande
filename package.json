{
  "name": "flaggenbande-platform-operations",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "operator:runner": "node --env-file-if-exists=.env.operator scripts/operator-runner.mjs",
    "operator:runner:once": "node --env-file-if-exists=.env.operator scripts/operator-runner.mjs --once",
    "operator:test": "node --test tests/operator-api.test.mjs tests/operator-runner.test.mjs",
    "operator:worker:dry-run": "npx --yes wrangler@4.112.0 deploy --dry-run --config cloud/operator-api/wrangler.toml",
    "operator:worker:deploy": "npm --prefix dashboard run build && npx --yes wrangler@4.112.0 deploy --config cloud/operator-api/wrangler.toml",
    "youtube:auth": "node --env-file-if-exists=.env.platforms scripts/youtube-auth.mjs",
    "upload:test": "node scripts/upload-staging.mjs",
    "test:oauth": "node --test tests/youtube-auth.test.mjs",
    "test:upload": "node --test tests/upload-staging.test.mjs"
  }
}
